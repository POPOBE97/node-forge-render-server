        "source": "let size = [\n  data[\"rects\"][index].width,\n  data[\"rects\"][index].height\n] as vec2\n\nlet position = [\n  data[\"rects\"][index].x - size[0] / 2 + size[0],\n  2400 - (data[\"rects\"][index].y - size[1] / 2 + size[1])\n] as vec2\n\nconst radius = data[\"rects\"][index].radius as float\n\nconst scale = [\n  size[0] / 100.0,\n  size[1] / 100.0,\n] as vec2\n\nreturn { position, scale, size, radius }",
